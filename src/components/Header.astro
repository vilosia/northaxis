---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
---

<header>
  <nav>
<h2>
  <a href="/" class="logo">
    <img src="/logo.svg" alt="NorthAxis" />
  </a>
</h2>

    <div class="nav-links">
      <a href="/blog">Notes</a>
      <a href="/about">About</a>
    </div>
  </nav>
</header>

<style>
header {
  margin: 0;
  padding: 1rem 1.5rem;
}

nav {
  max-width: 760px;
  margin: 0 auto;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

h2 {
  margin: 0;
  font-size: 1rem;
  font-weight: 600;
}

h2 a {
  text-decoration: none;
  color: inherit;
}

.nav-links {
  display: flex;
  gap: 1.5rem;
}

.nav-links a {
  text-decoration: none;
  color: inherit;
}

.logo {
  display: flex;
  align-items: center;
}

.logo img {
  height: 24px;
  width: auto;
  display: block;
}

.nav-links a:hover {
  opacity: 0.7;
}
</style>
