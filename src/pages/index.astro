---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			main {
				max-width: 760px;
				margin: 0 auto;
				padding: 6rem 1.5rem;
			}

			.hero {
				margin-bottom: 5rem;
			}

			h1 {
				font-size: clamp(3.5rem, 9vw, 7rem);
				line-height: 0.95;
				margin: 0 0 1.5rem;
				letter-spacing: -0.06em;
			}

			.statement {
				font-size: clamp(1.25rem, 2vw, 1.6rem);
				line-height: 1.7;
				max-width: 680px;
				color: rgb(var(--black));
			}

			.section-label {
				font-size: 0.85rem;
				letter-spacing: 0.08em;
				text-transform: uppercase;
				color: rgb(var(--gray));
				margin-bottom: 2rem;
			}

			.post {
				margin-bottom: 4rem;
			}

			.divider {
				border: 0;
				border-top: 1px solid rgba(var(--gray), 30%);
				margin: 4rem 0;
			}

			.essay-title {
				font-size: clamp(2rem, 4vw, 3.4rem);
				line-height: 1.05;
				letter-spacing: -0.04em;
				margin: 0 0 1.25rem;
			}

			.essay-title a {
				text-decoration: none;
				color: rgb(var(--black));
			}

			.essay-title a:hover {
				color: rgb(var(--accent));
			}

			.excerpt {
				font-size: 1.15rem;
				line-height: 1.8;
				color: rgb(var(--gray));
				margin-bottom: 1.5rem;
			}

			.read-link {
				font-size: 1rem;
				font-weight: 600;
			}
		</style>
	</head>

	<body>
		<Header />

		<main>
			<section class="hero">
				<h1>NorthAxis</h1>

				<p class="statement">
					Notes on design, AI, systems thinking, and building better products.
				</p>
			</section>

			<section>
				<p class="section-label">Latest Notes</p>

				{
					posts.map((post, index) => (
						<>
							<article class="post">
								<h2 class="essay-title">
									<a href={`/blog/${post.slug}/`}>{post.data.title}</a>
								</h2>

								<p class="excerpt">{post.data.description}</p>

								<p>
									<a class="read-link" href={`/blog/${post.slug}/`}>
										Continue Reading →
									</a>
								</p>
							</article>

							{index < posts.length - 1 && <hr class="divider" />}
						</>
					))
				}
			</section>
		</main>

		<Footer />
	</body>
</html>