---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const getPostUrl = (post) => {
	const slug = post.slug ?? post.id.replace(/\.mdx?$/, '');
	return `/blog/${slug}/`;
};
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />

		<style>
			main {
				max-width: 700px;
				margin: 0 auto;
				padding: 3rem 1.5rem 6rem;
			}

			.section-label {
				font-size: 1rem;
				font-weight: 400;
				color: rgb(var(--black));
				margin: 0 0 1.5rem;
			}

			.note-card {
				background: #fcfcfc;
				border: 1px solid #E9E8E8;
				border-radius: 16px;
				padding: 1.75rem 1.5rem;
				margin-bottom: 1.5rem;
			}

			.essay-title {
				font-size: 1.5rem;
				line-height: 1.25;
				letter-spacing: -0.03em;
				margin: 0 0 0.4rem;
			}

			.essay-title a {
				text-decoration: none;
				color: rgb(var(--black));
			}

			.essay-title a:hover {
				color: rgb(var(--accent));
			}

			.excerpt {
				font-size: 1rem;
				line-height: 1.6;
				color: rgb(var(--black));
				margin: 0 0 1.4rem;
			}

			.read-link {
				font-size: 1rem;
				font-weight: 400;
				text-decoration: none;
				color: rgb(var(--black));
			}

			.read-link:hover {
				color: rgb(var(--accent));
			}
		</style>
	</head>

	<body>
		<Header />

		<main>
			<section>
				<p class="section-label">Latest Notes</p>

				{
					posts.map((post) => (
						<article class="note-card">
							<h2 class="essay-title">
								<a href={getPostUrl(post)}>
									{post.data.title}
								</a>
							</h2>

							<p class="excerpt">
								{post.data.description}
							</p>

							<p>
								<a class="read-link" href={getPostUrl(post)}>
									Continue Reading →
								</a>
							</p>
						</article>
					))
				}
			</section>
		</main>

		<Footer />
	</body>
</html>