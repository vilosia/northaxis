---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const getPostUrl = (post) => {
	const slug = post.slug ?? post.id.replace(/\.mdx?$/, '');
	return `/blog/${slug}/`;
};
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />

		<style>
			main {
				max-width: 700px;
				margin: 0 auto;
				padding: 3rem 1.5rem 6rem;
			}

			.section-label {
				font-size: 1rem;
				font-weight: 400;
				color: rgb(var(--black));
				margin: 0 0 1.5rem;
			}

			.note-card-link {
				display: block;
				text-decoration: none;
				color: inherit;
				margin-bottom: 1.5rem;
			}

			.note-card {
				background: #fcfcfc;
				border: 1px solid #E9E8E8;
				border-radius: 16px;
				padding: 1.75rem 1.5rem;
				transition: border-color 0.2s ease, transform 0.2s ease;
				cursor: pointer;
			}

			.note-card-link:hover .note-card {
				border-color: #d8d7d7;
				transform: translateY(-2px);
			}

			.essay-title {
				font-size: 1.5rem;
				line-height: 1.25;
				letter-spacing: -0.03em;
				margin: 0 0 0.4rem;
				color: rgb(var(--black));
			}

			.excerpt {
				font-size: 1rem;
				line-height: 1.6;
				color: rgb(var(--black));
				margin: 0 0 1.4rem;
			}

			.read-link {
				font-size: 1rem;
				font-weight: 400;
				color: rgb(var(--black));
				margin: 0;
			}

			.note-card-link:hover .essay-title,
			.note-card-link:hover .read-link {
				color: rgb(var(--accent));
			}
		</style>
	</head>

	<body>
		<Header />

		<main>
			<section>
				<p class="section-label">Latest Notes</p>

				{
					posts.map((post) => (
						<a href={getPostUrl(post)} class="note-card-link">
							<article class="note-card">
								<h2 class="essay-title">
									{post.data.title}
								</h2>

								<p class="excerpt">
									{post.data.description}
								</p>

								<p class="read-link">
									Continue Reading →
								</p>
							</article>
						</a>
					))
				}
			</section>
		</main>

		<Footer />
	</body>
</html>