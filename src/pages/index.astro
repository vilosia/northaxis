---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			main {
				max-width: 760px;
				margin: 0 auto;
				padding: 6rem 1.5rem;
			}

			.hero {
				margin-bottom: 5rem;
			}

			.kicker {
				font-size: 0.9rem;
				letter-spacing: 0.08em;
				text-transform: uppercase;
				color: rgb(var(--gray));
				margin-bottom: 1rem;
			}

			h1 {
				font-size: clamp(3.5rem, 9vw, 7rem);
				line-height: 0.95;
				margin: 0 0 1.5rem;
				letter-spacing: -0.06em;
			}

			.statement {
				font-size: clamp(1.25rem, 2vw, 1.6rem);
				line-height: 1.7;
				max-width: 680px;
				color: rgb(var(--black));
			}

			.divider {
				border: 0;
				border-top: 1px solid rgba(var(--gray), 30%);
				margin: 4rem 0;
			}

			.section-label {
				font-size: 0.85rem;
				letter-spacing: 0.08em;
				text-transform: uppercase;
				color: rgb(var(--gray));
				margin-bottom: 1rem;
			}

			.essay-title {
				font-size: clamp(2rem, 4vw, 3.4rem);
				line-height: 1.05;
				letter-spacing: -0.04em;
				margin: 0 0 1.25rem;
			}

			.essay-title a {
				text-decoration: none;
				color: rgb(var(--black));
			}

			.essay-title a:hover {
				color: rgb(var(--accent));
			}

			.excerpt {
				font-size: 1.15rem;
				line-height: 1.8;
				color: rgb(var(--gray));
				margin-bottom: 1.5rem;
			}

			.read-link {
				font-size: 1rem;
				font-weight: 600;
			}

			.about {
				font-size: 1.1rem;
				line-height: 1.8;
				color: rgb(var(--gray));
			}
		</style>
	</head>

	<body>
		<Header />

		<main>
			<section class="hero">
  <h1>NorthAxis</h1>
  <p>Notes on design, AI, systems thinking, and the craft of building better products.</p>
</section>

			<section>
  <h2 class="section-title">Latest Notes</h2>
</section>

			<section>
			

				<h2 class="essay-title">
					<a href="/blog/the-value-of-designers-in-the-age-of-ai/">
						The Value of Designers in the Age of AI
					</a>
				</h2>

				<p class="excerpt">
					AI may not replace designers, but it is changing where design value comes from:
					less from execution, more from judgment, problem framing, and understanding.
				</p>

				<p>
					<a class="read-link" href="/blog/the-value-of-designers-in-the-age-of-ai/">
						Continue Reading →
					</a>
				</p>
			</section>

			<hr class="divider" />

			<section>
				<p class="section-label">About</p>

				<p class="about">
					NorthAxis is an independent publication exploring AI, systems, design,
					human behavior, and the patterns that connect them.
				</p>

				<p>
					<a class="read-link" href="/about">
						Read About NorthAxis →
					</a>
				</p>
			</section>
		</main>

		<Footer />
	</body>
</html>