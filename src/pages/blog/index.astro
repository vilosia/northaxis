---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_DESCRIPTION } from '../../consts';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title="Notes | NorthAxis" description={SITE_DESCRIPTION} />

		<style>
			main {
				max-width: 860px;
				margin: 0 auto;
				padding: 3rem 1.5rem 6rem;
			}

			.post-list {
				list-style: none;
				padding: 0;
				margin: 0;
			}

			.note-card {
				background: #fcfcfc;
				border: 1px solid rgba(var(--gray), 15%);
				border-radius: 16px;
				padding: 2rem;
				margin-bottom: 1rem;
				transition: all 0.2s ease;
			}

			.note-card:hover {
				border-color: rgba(var(--gray), 25%);
			}

			.note-card a {
				text-decoration: none;
				color: rgb(var(--black));
			}

			.note-card a:hover h2 {
				color: rgb(var(--accent));
			}

			.note-card h2 {
				margin: 0 0 0.5rem 0;
				font-size: clamp(1.8rem, 4vw, 3rem);
				line-height: 1.08;
				letter-spacing: -0.04em;
			}

			.date {
				margin: 0 0 0.9rem 0;
				color: rgb(var(--gray));
				font-size: 0.9rem;
			}

			.description {
				margin: 0;
				color: rgb(var(--gray));
				font-size: 1.05rem;
				line-height: 1.8;
			}
		</style>
	</head>

	<body>
		<Header />

		<main>
			<ul class="post-list">
				{
					posts.map((post) => (
						<li class="note-card">
							<a href={`/blog/${post.id}/`}>
								<h2>{post.data.title}</h2>

								<p class="date">
									<FormattedDate date={post.data.pubDate} />
								</p>

								{post.data.description && (
									<p class="description">
										{post.data.description}
									</p>
								)}
							</a>
						</li>
					))
				}
			</ul>
		</main>

		<Footer />
	</body>
</html>