---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_DESCRIPTION } from '../../consts';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title="Essays | NorthAxis" description={SITE_DESCRIPTION} />
		<style>
			main {
				width: 720px;
				max-width: calc(100% - 2em);
				margin: auto;
				padding: 3em 1em;
			}

			.page-title {
				margin-bottom: 0.5em;
			}

			.page-description {
				color: rgb(var(--gray));
				font-size: 1.1em;
				margin-bottom: 3em;
			}

			.post-list {
				list-style: none;
				padding: 0;
				margin: 0;
			}

			.post-item {
				padding: 1.75em 0;
				border-bottom: 1px solid rgba(var(--gray), 25%);
			}

			.post-item a {
				text-decoration: none;
				color: rgb(var(--black));
			}

			.post-item a:hover h2 {
				color: rgb(var(--accent));
			}

			.post-item h2 {
				margin: 0 0 0.4em 0;
				font-size: 1.5em;
				line-height: 1.25;
			}

			.date {
				margin: 0 0 0.75em 0;
				color: rgb(var(--gray));
				font-size: 0.9em;
			}

			.description {
				margin: 0;
				color: rgb(var(--gray));
				line-height: 1.6;
			}
		</style>
	</head>

	<body>
		<Header />

		<main>
			<h1 class="page-title">Essays</h1>
			<p class="page-description">
				Observations, questions, and frameworks on AI, systems, design, and human behavior.
			</p>

			<ul class="post-list">
				{
					posts.map((post) => (
						<li class="post-item">
							<a href={`/blog/${post.id}/`}>
								<h2>{post.data.title}</h2>
								<p class="date">
									<FormattedDate date={post.data.pubDate} />
								</p>
								{post.data.description && (
									<p class="description">{post.data.description}</p>
								)}
							</a>
						</li>
					))
				}
			</ul>
		</main>

		<Footer />
	</body>
</html>
