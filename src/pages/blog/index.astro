---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_DESCRIPTION } from '../../consts';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title="Notes | NorthAxis" description={SITE_DESCRIPTION} />

		<style>
			main {
				max-width: 700px;
				margin: 0 auto;
				padding: 3rem 1.5rem 6rem;
			}

			.post-list {
				list-style: none;
				padding: 0;
				margin: 0;
			}

			.note-card {
				background: #FCFCFC;
				border: 1px solid #E9E8E8;
				border-radius: 16px;
				padding: 1.75rem 1.5rem;
				margin-bottom: 1.5rem;
			}

			.note-card a {
				text-decoration: none;
				color: rgb(var(--black));
				display: block;
			}

			.note-card h2 {
				margin: 0 0 0.4rem;
				font-size: 1.5rem;
				line-height: 1.25;
				letter-spacing: -0.03em;
				font-weight: 700;
			}

			.note-card a:hover h2 {
				color: rgb(var(--accent));
			}

			.date {
				margin: 0 0 0.75rem;
				font-size: 0.9rem;
				color: rgb(var(--gray));
			}

			.description {
				margin: 0;
				font-size: 1rem;
				line-height: 1.6;
				color: rgb(var(--black));
			}
		</style>
	</head>

	<body>
		<Header />

		<main>
			<ul class="post-list">
				{
					posts.map((post) => (
						<li class="note-card">
							<a href={`/blog/${post.id}/`}>
								<h2>{post.data.title}</h2>

								<p class="date">
									<FormattedDate date={post.data.pubDate} />
								</p>

								{post.data.description && (
									<p class="description">
										{post.data.description}
									</p>
								)}
							</a>
						</li>
					))
				}
			</ul>
		</main>

		<Footer />
	</body>
</html>